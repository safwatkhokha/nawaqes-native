# ════════════════════════════════════════════════════════════════════
#  Nawaqes — Environment Variables Template
#  Copy this file to .env and fill in real values.
#  In production, set these as platform Secrets (HF Spaces / Render / Koyeb).
# ════════════════════════════════════════════════════════════════════

# ─── Runtime ────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Public URL of the deployment (used for share links, APK download URLs)
APP_URL=https://your-space-name.hf.space

# ─── Security (REQUIRED in production) ──────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_PLUS_CHAR_HEX_STRING
JWT_EXPIRES_IN=7d

# ─── Admin & Owner accounts (REQUIRED in production) ────────────────
ADMIN_EMAIL=admin@nawaqes.app
ADMIN_PASSWORD=ChangeMe!Min8chars
OWNER_EMAIL=owner@nawaqes.app
OWNER_PASSWORD=ChangeMe!Min8chars
OWNER_PHONE=01000000001

# Set to true to force-reset admin/owner password on next boot
FORCE_RESET_ADMIN_PASSWORD=false
FORCE_RESET_OWNER_PASSWORD=false

# ─── Hugging Face Backup (auto DB + uploads backup to a HF dataset) ─
# Create a token at: https://huggingface.co/settings/tokens (write perm)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx
HF_BACKUP_REPO=safwatkhokha/nawaqes-backup

# ─── Firebase Cloud Messaging (Push Notifications) ──────────────────
# Either set FIREBASE_SERVICE_ACCOUNT (file path) OR the individual vars below.
# Service account JSON file path (recommended). Place it in /data/ for persistence.
FIREBASE_SERVICE_ACCOUNT=/data/firebase-service-account.json
# Alternative: individual env vars (the server reads these if no file is set)
FIREBASE_PROJECT_ID=nawaqes-app
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@nawaqes-app.iam.gserviceaccount.com
# Multi-line private key — wrap with quotes and use \n escapes
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# Client config (for the web PWA — VAPID key for FCM web push)
FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FIREBASE_AUTH_DOMAIN=nawaqes-app.firebaseapp.com
FIREBASE_STORAGE_BUCKET=nawaqes-app.appspot.com
FIREBASE_MESSAGING_SENDER_ID=000000000000
FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
FIREBASE_VAPID_KEY=BLXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── WebRTC TURN/STUN (for audio/video calls) ───────────────────────
# Get a free TURN from https://www.metered.ca/ or self-host coturn
METERED_TURN_URL=
METERED_TURN_USERNAME=
METERED_TURN_CREDENTIAL=

# ─── Optional: Disable HMR in dev (useful behind proxies) ───────────
# DISABLE_HMR=false
