{
  "expo": {
    "name": "Nawaqes",
    "slug": "nawaqes",
    "owner": "safwatkhokhas-team",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "android": {
      "package": "com.nawaqes.app",
      "versionCode": 20,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "READ_EXTERNAL_STORAGE",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Nawaqes needs camera access for photos, videos, and live streaming",
          "microphonePermission": "Nawaqes needs microphone access for audio recording and live streaming"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#f97316"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3de290a7-6c4e-4b94-a899-ee09b101ea1c"
      }
    }
  }
}
